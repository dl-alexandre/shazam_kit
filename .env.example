# ShazamKit API Configuration
# Get credentials from: https://developer.apple.com/documentation/shazamkit

# Required: Your Apple Developer Team ID (10 characters)
SHAZAM_TEAM_ID=

# Required: ShazamKit Key ID (10 characters)
# Create in Apple Developer Portal: Certificates, Identifiers & Profiles → Keys → ShazamKit
SHAZAM_KEY_ID=

# Required: Private Key (p8 format - full content including BEGIN/END lines)
# Download when creating the ShazamKit key (can only be downloaded once!)
SHAZAM_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----
YOUR_KEY_CONTENT_HERE
-----END EC PRIVATE KEY-----"

# Alternative: Path to private key file
SHAZAM_PRIVATE_KEY_PATH=/path/to/your/AuthKey.p8

# Optional: Base URL (default: https://api.shazam.com)
# SHAZAM_BASE_URL=https://api.shazam.com

# Optional: Token TTL in seconds (default: 1200 = 20 minutes)
# SHAZAM_TOKEN_TTL_SECONDS=1200

# Optional: Req options for HTTP client (JSON format)
# SHAZAM_REQ_OPTIONS={"timeout": 30000}
